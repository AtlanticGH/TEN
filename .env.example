## Client (Vite) — safe to expose to the browser
# From Supabase Dashboard → Project Settings → API
# https://aidcfsxtjcnzqkzumtwt.supabase.co
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

## Client (Vite) — optional
# Render: set this to your backend service URL, e.g. https://app-backend.onrender.com
# Local dev: leave blank to use same-origin `/api/*`
VITE_API_URL=

## Server (Vercel Serverless Functions in /api) — NEVER expose to the browser
# Same as VITE_SUPABASE_URL (kept separate for clarity in server env)
SUPABASE_URL=
# Supabase Dashboard → Project Settings → API → service_role key (secret)
SUPABASE_SERVICE_ROLE_KEY=

## Optional (used by /api/inviteApplicant.js and password-reset redirects)
SITE_URL=http://localhost:5173
# Supabase Dashboard → Auth → URL Configuration → Redirect URLs must include:
#   http://localhost:5173/reset-password  (local)
#   https://<your-production-domain>/reset-password  (prod)

## Email (Resend — get key at resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@theembernetwork.com
VITE_SITE_URL=https://theembernetwork.com

## Server (legacy SMTP — not used for application decisions)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

## Bootstrap — first CMS admin (scripts/create-admin.mjs; gitignore real values in .env.local)
# ADMIN_EMAIL=you@company.com
# ADMIN_PASSWORD=YourSecurePass1
# ADMIN_NAME=Site Administrator

## Server (CORS)
# Render: set to your frontend static site origin, e.g. https://app-frontend.onrender.com
FRONTEND_ORIGIN=

